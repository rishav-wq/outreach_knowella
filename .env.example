# --- LLM (default provider: gemini) ---
# Google AI Studio key for the OpenAI-compatible Gemini endpoint
GOOGLE_API_KEY=

# Optional alternate providers (engine can route per-step). Leave blank if unused.
GROQ_API_KEY=
OPENAI_API_KEY=

# --- Research ---
TAVILY_API_KEY=

# --- Email verification (drop dead addresses before sending) ---
MILLIONVERIFIER_API_KEY=

# --- Email enrichment (find emails for approved leads; free tier) ---
HUNTER_API_KEY=

# --- Leads + Sending (Apollo) ---
APOLLO_API_KEY=

# --- Database ---
MONGO_URI=

# --- Authentication (Clerk) ---
# Leave BLANK for local dev to keep the API open. Set both to require sign-in.
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
# Optional: only if you use a custom Clerk domain (else derived from the publishable key)
# CLERK_ISSUER=https://your-app.clerk.accounts.dev

# Access control: restrict WHO can use the app (else any successful sign-up gets in).
# Set either or both (comma-separated). Empty = anyone signed in is allowed.
ALLOWED_EMAIL_DOMAINS=      # e.g. knowella.com
ALLOWED_EMAILS=             # e.g. rishav@knowella.com,sid@knowella.com

# --- CORS (production) ---
# Comma-separated origins allowed to call the API, e.g. the deployed web URL.
# Localhost dev origins are always allowed.
ALLOWED_ORIGINS=
