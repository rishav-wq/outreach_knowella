# Copy to web/.env for local dev (or set these in Render for the static site).

# Clerk publishable key. Leave BLANK to run the app without a sign-in wall (local dev).
VITE_CLERK_PUBLISHABLE_KEY=

# Backend API base URL. Defaults to http://127.0.0.1:8010 when unset (local dev).
# In production set this to the deployed API, e.g. https://outreach-api.onrender.com
VITE_API_BASE=
