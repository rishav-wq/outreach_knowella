# Baked into the production build (npm run build). The publishable key is PUBLIC
# by design — it already ships in the client bundle, so it's safe to commit.
# VITE_API_BASE empty → the app calls the API same-origin (overrides web/.env's
# localhost value, since .env.production wins in a production build).
VITE_CLERK_PUBLISHABLE_KEY=pk_test_YmFsYW5jZWQtbWFuLTI0LmNsZXJrLmFjY291bnRzLmRldiQ
VITE_API_BASE=
